# Google Gemini AI API Key — server-side only, never exposed to the browser
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Formspree contact form endpoint
# Sign up at https://formspree.io, create a form, paste the endpoint below
REACT_APP_FORMSPREE_ENDPOINT=https://formspree.io/f/your_form_id
